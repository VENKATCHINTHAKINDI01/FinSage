# ============================================
# FinSage AI — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# APP CONFIGURATION
# ============================================
ENVIRONMENT=development
DEBUG=true
APP_NAME="FinSage AI"
API_VERSION=v1
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# DATABASE
# ============================================
POSTGRES_URL=postgresql+asyncpg://finsage_user:finsage_password@localhost:5432/finsage
POSTGRES_ECHO=false
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# ============================================
# QDRANT VECTOR DB
# ============================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ============================================
# GROQ LLM API
# ============================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.7
GROQ_MAX_TOKENS=2048
GROQ_TIMEOUT=30

# ============================================
# WEB SEARCH
# ============================================
SEARCH_TAVILY_API_KEY=your_tavily_api_key_here
SEARCH_SERPER_API_KEY=your_serper_api_key_here
SEARCH_MAX_RESULTS=5

# ============================================
# JWT & AUTHENTICATION
# ============================================
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# TELEGRAM BOT
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=

# ============================================
# EMAIL NOTIFICATIONS
# ============================================
EMAIL_SMTP_HOST=smtp.resend.com
EMAIL_SMTP_PORT=465
EMAIL_SENDER_EMAIL=noreply@finsage.ai
EMAIL_SENDER_NAME="FinSage AI"
EMAIL_RESEND_API_KEY=your_resend_api_key_here

# ============================================
# AWS S3 (Document Vault)
# ============================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_BUCKET_NAME=finsage-documents
AWS_REGION=ap-south-1
# AWS_ENDPOINT_URL=http://localhost:9000  # Uncomment for MinIO self-hosted

# ============================================
# Development: Quick Start
# ============================================
# For local development with Docker Compose:
# 1. Create .env from this template
# 2. Get API keys from:
#    - Groq: console.groq.com
#    - Tavily: tavily.com
#    - Telegram: @BotFather
#    - Resend: resend.com
# 3. Run: docker-compose up
